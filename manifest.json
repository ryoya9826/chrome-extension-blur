{
  "manifest_version": 3,
  "name": "chrome-extension-blur",
  "version": "0.1",
  "description": "いい感じにブローをかけてくれる",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}